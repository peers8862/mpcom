#!/usr/bin/env bash
# bin/newpost — Generate a new Jekyll post for mpcom
set -euo pipefail

POSTS_DIR="$(cd "$(dirname "$0")/.." && pwd)/_posts"

# --- Gather metadata ---
read -rp "Title: " TITLE
SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')
DATE=$(date +%Y-%m-%d)
DATETIME=$(date +"%Y-%m-%d %H:%M:%S %z")

read -rp "Categories — type your own or pick from existing? [t/p]: " CAT_MODE

# Gather existing categories from all posts
mapfile -t ALL_CATS < <(grep -h '^categories:' "$POSTS_DIR"/*.markdown 2>/dev/null \
  | sed 's/^categories:[[:space:]]*//' \
  | tr ' ' '\n' \
  | sort -u \
  | grep -v '^$')

SELECTED_CATS=()

if [[ "$CAT_MODE" =~ ^[Pp]$ && ${#ALL_CATS[@]} -gt 0 ]]; then
  AVAILABLE_CATS=("${ALL_CATS[@]}")
  while true; do
    echo "Existing categories:"
    for i in "${!AVAILABLE_CATS[@]}"; do
      echo "  $((i + 1))) ${AVAILABLE_CATS[$i]}"
    done
    read -rp "Pick a number or type a category: " CAT_INPUT
    # Check if input is a number referencing the list
    if [[ "$CAT_INPUT" =~ ^[0-9]+$ ]] && [[ "$CAT_INPUT" -ge 1 ]] && [[ "$CAT_INPUT" -le ${#AVAILABLE_CATS[@]} ]]; then
      PICKED="${AVAILABLE_CATS[$((CAT_INPUT - 1))]}"
      SELECTED_CATS+=("$PICKED")
      # Remove picked item from available list
      unset 'AVAILABLE_CATS[$((CAT_INPUT - 1))]'
      AVAILABLE_CATS=("${AVAILABLE_CATS[@]}")
    else
      # Typed a category directly (existing or new)
      CAT_INPUT=$(echo "$CAT_INPUT" | tr ',' ' ' | tr -s ' ')
      for c in $CAT_INPUT; do
        SELECTED_CATS+=("$c")
      done
    fi
    echo "  Selected so far: ${SELECTED_CATS[*]}"
    read -rp "Add more? [y/N]: " MORE
    if [[ ! "$MORE" =~ ^[Yy]$ ]]; then
      break
    fi
  done
else
  read -rp "Categories (space-separated) []: " CAT_INPUT
  CAT_INPUT=$(echo "$CAT_INPUT" | tr ',' ' ' | tr -s ' ')
  for c in $CAT_INPUT; do
    SELECTED_CATS+=("$c")
  done
fi

CATEGORIES="${SELECTED_CATS[*]}"
echo "Categories: $CATEGORIES"
read -rp "Confirm? [Y/n]: " CONFIRM_CATS
if [[ "$CONFIRM_CATS" =~ ^[Nn]$ ]]; then
  read -rp "Categories (space-separated): " CATEGORIES
  CATEGORIES=$(echo "$CATEGORIES" | tr ',' ' ' | tr -s ' ')
fi
read -rp "Image path (blank for none): " IMAGE

CAPTION=""
if [[ -n "$IMAGE" ]]; then
  read -rp "Caption: " CAPTION
fi

read -rp "URL (user/repo for GitHub, full link, or blank): " URL_INPUT
URL=""
if [[ -n "$URL_INPUT" ]]; then
  if [[ "$URL_INPUT" =~ ^https?:// ]]; then
    URL="$URL_INPUT"
  elif [[ "$URL_INPUT" =~ ^[^/]+/[^/]+$ ]]; then
    URL="https://github.com/${URL_INPUT}"
  else
    URL="$URL_INPUT"
  fi
fi

FILENAME="${POSTS_DIR}/${DATE}-${SLUG}.markdown"

# --- Preface (optional, asked early) ---
echo ""
read -rp "Add a preface? (brief intro shown before main content) [y/N]: " ADD_PREFACE
PREFACE=""
if [[ "$ADD_PREFACE" =~ ^[Yy]$ ]]; then
  echo "Type preface (Ctrl-D to finish):"
  PREFACE=$(cat)
fi

# --- Build front matter ---
FM_LINES="---
layout: post
title:  \"${TITLE}\"
date:   ${DATETIME}
categories: ${CATEGORIES}"

if [[ -n "$IMAGE" ]]; then
  FM_LINES="${FM_LINES}
image: ${IMAGE}
caption: ${CAPTION}"
fi

if [[ -n "$URL" ]]; then
  FM_LINES="${FM_LINES}
url: ${URL}"
fi

FRONTMATTER="${FM_LINES}
---"

# --- Helper: write front matter + preface to file ---
write_header() {
  echo "$FRONTMATTER" > "$FILENAME"
  if [[ -n "$PREFACE" ]]; then
    printf "\n%s\n\n---\n\n\n" "$PREFACE" >> "$FILENAME"
  else
    printf "\n" >> "$FILENAME"
  fi
}

# --- Helper: convert raw URLs in file to markdown links ---
# Skips URLs already inside markdown link syntax [...](...) or front matter
# Strips trailing punctuation (.,:;!?) from captured URLs
linkify() {
  sed -i -E '
    /^---$/,/^---$/b
    /\[.*\]\(https?:\/\//b
    s|(https?://[^ )<>]+[^. )<>,;:!?])([.,;:!?])?|[\1](\1)\2|g
  ' "$FILENAME"
}

# --- Helper: prompt for preface if skipped earlier ---
ask_preface_again() {
  if [[ -z "$PREFACE" ]]; then
    echo ""
    read -rp "Content is set. Add a preface now? [y/N]: " ADD_PREFACE_LATE
    if [[ "$ADD_PREFACE_LATE" =~ ^[Yy]$ ]]; then
      echo "Type preface (Ctrl-D to finish):"
      PREFACE=$(cat)
    fi
  fi
}

# --- Body content ---
echo ""
echo "How do you want to add body content?"
echo "  1) Paste/type directly (end with Ctrl-D on empty line)"
echo "  2) Open in nano"
echo "  3) Open in Sublime Text"
echo "  4) Open in Obsidian (creates file, opens vault)"
echo "  5) Empty (just create the file)"
echo "  6) Import from a file (markdown or text)"
read -rp "Choice [1-6]: " CHOICE

case "$CHOICE" in
  1)
    echo "Type or paste content below (Ctrl-D to finish):"
    BODY=$(cat)
    ask_preface_again
    write_header
    printf "%s\n" "$BODY" >> "$FILENAME"
    linkify
    echo "Created: $FILENAME"
    ;;
  2)
    ask_preface_again
    write_header
    nano "$FILENAME"
    linkify
    echo "Created: $FILENAME"
    ;;
  3)
    ask_preface_again
    write_header
    subl --wait "$FILENAME"
    linkify
    echo "Created: $FILENAME"
    ;;
  4)
    ask_preface_again
    write_header
    ENCODED_PATH=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$FILENAME")
    open "obsidian://open?path=${ENCODED_PATH}" 2>/dev/null || \
      xdg-open "obsidian://open?path=${ENCODED_PATH}" 2>/dev/null
    echo "Created: $FILENAME (opened in Obsidian)"
    read -rp "Press Enter when done editing in Obsidian..."
    linkify
    echo "Done."
    ;;
  5)
    ask_preface_again
    write_header
    echo "Created: $FILENAME"
    ;;
  6)
    read -rp "Path to file: " SRCFILE
    SRCFILE="${SRCFILE/#\~/$HOME}"
    if [[ ! -f "$SRCFILE" ]]; then
      echo "Error: File not found: $SRCFILE"
      exit 1
    fi
    ask_preface_again
    write_header
    cat "$SRCFILE" >> "$FILENAME"
    linkify
    echo "Created: $FILENAME (imported from $SRCFILE)"
    ;;
  *)
    echo "Invalid choice. Creating empty post."
    write_header
    echo "Created: $FILENAME"
    ;;
esac
